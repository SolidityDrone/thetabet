{
  "expo": {
    "name": "ThetaBet",
    "slug": "thetabet",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-square.png",
    "scheme": "thetabet",
    "newArchEnabled": true,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "io.thetabet.app",
      "statusBar": {
        "style": "light",
        "backgroundColor": "#000000"
      }
    },
    "splash": {
      "image": "./assets/images/splash-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000",
      "dark": {
        "backgroundColor": "#000000"
      }
    },
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "@qvac/sdk/expo-plugin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-logo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos for your chat avatar."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29,
            "compileSdkVersion": 36,
            "buildToolsVersion": "36.0.0",
            "ndkVersion": "27.1.12297006",
            "usesCleartextTraffic": true
          }
        }
      ],
      "./plugins/withAndroidSubprojects.js",
      "./plugins/withAndroidCleartextLocalhost.js",
      "./plugins/withAndroidNdk27.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
