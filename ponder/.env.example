# Ponder indexer for ThetaBet vaults, positions, and bets.
# Without DATABASE_URL, Ponder uses embedded PGlite (good for local dev).
# Set DATABASE_URL to use external Postgres in production.

# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ponder
PONDER_RPC_URL_1=http://127.0.0.1:8545
